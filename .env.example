# ============================================================================
# Exemple de variables d'environnement pour Docker Compose
# ----------------------------------------------------------------------------
# Utilisation:
#   1) Copier ce fichier en ".env" a la racine du projet
#   2) Ajuster les valeurs selon ta machine
#   3) Verifier la resolution: docker compose -f docker/docker-compose.simple.yml config
#   4) (Optionnel) Definir le nom de projet Compose:
#      COMPOSE_PROJECT_NAME=tech-app-devoir-ii
# ============================================================================

# Nom du projet Docker Compose (prefixe conteneurs/volumes/reseaux).
# Utile pour eviter les collisions si tu as plusieurs stacks locales.
COMPOSE_PROJECT_NAME=tech-app-devoir-ii

# ----------------------------------------------------------------------------
# BUILD (args passes au Dockerfile)
# ----------------------------------------------------------------------------
# Tag de l'image NVIDIA CUDA de base.
# Garde une version stable que tes drivers supportent.
CUDA_IMAGE_TAG=12.6.3-cudnn-runtime-ubuntu24.04

# Active (1) ou desactive (0) l'installation des dependances RAPIDS.
# 1 requis pour utiliser les modeles GPU cuML/CuPy dans le notebook.
ENABLE_RAPIDS=1

# Mode des requirements:
# - freeze: versions verrouillees (.lock.txt), reproductible
# - latest: versions non figees (.txt), plus recent mais plus risque
REQUIREMENTS_MODE=freeze

# ----------------------------------------------------------------------------
# RUNTIME GPU / CONTENEUR
# ----------------------------------------------------------------------------
# Fuseau horaire du conteneur (logs et dates coherentes).
TZ=Etc/UTC

# Selection GPU:
# - all : toutes les cartes visibles
# - 0   : GPU index 0 seulement
# - 0,1 : plusieurs GPUs
NVIDIA_VISIBLE_DEVICES=all

# Capacites exposees par le runtime NVIDIA.
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Bypass de certaines checks runtime NVIDIA.
NVIDIA_DISABLE_REQUIRE=1

# ----------------------------------------------------------------------------
# NOTEBOOK (service "notebook")
# ----------------------------------------------------------------------------
# Port local expose pour JupyterLab.
JUPYTER_PORT=8888

# Token d'acces JupyterLab.
# Change cette valeur si la machine est partagee.
JUPYTER_TOKEN=techapp

# ----------------------------------------------------------------------------
# PIPELINE (service "pipeline")
# ----------------------------------------------------------------------------
# Limites memoire RAM du conteneur pipeline.
PIPELINE_MEM_LIMIT=24g
PIPELINE_MEMSWAP_LIMIT=24g

# Taille de /dev/shm (important pour certains jobs Python/ML).
PIPELINE_SHM_SIZE=8g

# Limite CPU du conteneur pipeline.
PIPELINE_CPUS=12.0
